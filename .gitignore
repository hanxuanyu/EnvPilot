# ============================================================
# EnvPilot 项目根目录 .gitignore
# ============================================================

# ── Wails 构建产物 ──────────────────────────────────────────
build/bin/

# ── Go 编译产物 ─────────────────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/

# ── 运行时数据（本地生成，不提交）──────────────────────────
# 用户本地数据库和加密 salt，含敏感信息，绝对不提交
data/
# 日志文件
logs/

# ── 配置覆盖（本地开发专用）────────────────────────────────
# 如需本地覆盖配置，使用 config.local.yaml，不要修改 config.yaml
config/config.local.yaml

# ── 编辑器与 IDE ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── 操作系统 ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── 临时文件 ─────────────────────────────────────────────────
*.tmp
*.temp
.env
.env.local
